{
    "version": 8,
    "name": "osm-raster",
    "sources": {
		"osm": {
			"type": "raster",
			"tiles": ["https://a.tile.openstreetmap.org/{z}/{x}/{y}.png"],
			"tileSize": 256
		}
	},
    "layers": [
        {
            "id": "osm",
            "type": "raster",
            "source": "osm",
            "paint": {
                "raster-hue-rotate": 0,
                "raster-contrast": 0.2,
                "raster-saturation": 0.2,
                "raster-brightness-min": 0.1,
                "raster-brightness-max": 0.9
            }
        }
    ]
}
